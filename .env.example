APP_NAME=ExpedientLog
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=Africa/Lusaka
APP_URL=http://localhost/ExpedientLog

# Database (set these from your Railway DB plugin)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=exp_log
DB_USER=root
DB_PASS=

# Storage: Railway filesystem is ephemeral — use an object storage for persistent uploads
# S3_BUCKET=your-bucket
# S3_KEY=...
# S3_SECRET=...
# S3_REGION=...
